<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- A minimal window theme; all real UI is Compose (see ui/theme/Theme.kt). The window is tinted
         to the design bg.base so app launch shows no white flash. -->
    <style name="Theme.MlS" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/bg_base</item>
        <item name="android:statusBarColor">@color/bg_base</item>
        <item name="android:navigationBarColor">@color/bg_base</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
