<?xml version="1.0" encoding="utf-8"?>
<!-- Exclude EVERYTHING from cloud backup and device-to-device transfer. The local cache is encrypted
     and the Keystore unlock key is non-exportable, but we additionally refuse to let any app data
     leave the device through backup channels. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
