{
    "name": "my-little-secrets",
    "version": 1,
    "colors": [
        {
            "name": "bg.base",
            "hex": "#16130F",
            "doc": "App background — warm near-black."
        },
        {
            "name": "bg.elevated",
            "hex": "#1E1A15",
            "doc": "Raised surfaces: cards, sheets, the editor pane."
        },
        {
            "name": "bg.overlay",
            "hex": "#231E18",
            "doc": "Menus/popovers — one step above elevated."
        },
        {
            "name": "border.hairline",
            "hex": "#2A251E",
            "doc": "1px hairline separators and input borders."
        },
        {
            "name": "text.primary",
            "hex": "#EDE6DA",
            "doc": "Primary reading/title text on dark surfaces."
        },
        {
            "name": "text.secondary",
            "hex": "#A39A8B",
            "doc": "Secondary text: metadata, captions, placeholders."
        },
        {
            "name": "text.disabled",
            "hex": "#A39A8B61",
            "doc": "Disabled text — secondary at 38% alpha."
        },
        {
            "name": "accent",
            "hex": "#C9A26B",
            "doc": "The single brand accent — muted amber. Interactive emphasis."
        },
        {
            "name": "accent.on",
            "hex": "#16130F",
            "doc": "Text/icon drawn ON an amber fill — the base surface, for contrast."
        },
        {
            "name": "accent.subtle",
            "hex": "#C9A26B1F",
            "doc": "Amber wash for selected rows/chips — accent at ~12% alpha."
        },
        {
            "name": "state.hover",
            "hex": "#EDE6DA0F",
            "doc": "Hover overlay — primary text at ~6% alpha."
        },
        {
            "name": "state.pressed",
            "hex": "#EDE6DA1A",
            "doc": "Pressed overlay — primary text at ~10% alpha."
        },
        {
            "name": "focus.ring",
            "hex": "#C9A26B",
            "doc": "Keyboard-focus ring — the accent, drawn at 2px."
        },
        {
            "name": "semantic.danger",
            "hex": "#C16A52",
            "doc": "Destructive-action signal (delete). A muted terracotta status color, not a second accent."
        },
        {
            "name": "semantic.danger.on",
            "hex": "#16130F",
            "doc": "Text/icon on a danger fill."
        },
        {
            "name": "scrim",
            "hex": "#0B0907B3",
            "doc": "Modal scrim — near-black at ~70% alpha."
        }
    ],
    "fonts": [
        {
            "name": "serif",
            "families": [
                "Spectral",
                "Newsreader",
                "Source Serif 4",
                "Georgia",
                "serif"
            ],
            "doc": "Titles and long-form reading. Editorial, warm."
        },
        {
            "name": "grotesque",
            "families": [
                "Geist",
                "IBM Plex Sans",
                "Inter",
                "system-ui",
                "sans-serif"
            ],
            "doc": "UI chrome: buttons, labels, navigation, metadata."
        }
    ],
    "type": [
        {
            "name": "display",
            "font": "serif",
            "sizeSp": 28,
            "lineSp": 34,
            "weight": 600,
            "letterSpacingEm": 0.0,
            "color": "text.primary",
            "doc": "Note title in the editor; empty-state headline."
        },
        {
            "name": "title",
            "font": "serif",
            "sizeSp": 19,
            "lineSp": 26,
            "weight": 500,
            "letterSpacingEm": 0.0,
            "color": "text.primary",
            "doc": "Note title in the list."
        },
        {
            "name": "reading",
            "font": "serif",
            "sizeSp": 16,
            "lineSp": 27,
            "weight": 400,
            "letterSpacingEm": 0.0,
            "color": "text.primary",
            "doc": "Note body — long-form reading."
        },
        {
            "name": "ui.label",
            "font": "grotesque",
            "sizeSp": 14,
            "lineSp": 20,
            "weight": 500,
            "letterSpacingEm": 0.0,
            "color": "text.primary",
            "doc": "Form labels, section headers, active nav."
        },
        {
            "name": "ui.body",
            "font": "grotesque",
            "sizeSp": 14,
            "lineSp": 21,
            "weight": 400,
            "letterSpacingEm": 0.0,
            "color": "text.primary",
            "doc": "Default UI text, list subtitles."
        },
        {
            "name": "button",
            "font": "grotesque",
            "sizeSp": 14,
            "lineSp": 18,
            "weight": 600,
            "letterSpacingEm": 0.01,
            "color": "text.primary",
            "doc": "Button labels."
        },
        {
            "name": "meta",
